# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# Jupyter
.ipynb_checkpoints/
*-checkpoint.ipynb

# Data cache — too large for git
data_cache/raw/
data_cache/processed/
*.parquet
*.csv
*.feather

# Exception: small versioned outputs in /results/ ARE tracked.
# Order matters — these unignore must come AFTER the *.csv/*.parquet rules above.
!results/**/*.csv
!results/**/*.parquet
!results/**/*.feather
!results/**/*.json

# Model artifacts
# .txt (LightGBM text format, ~3MB) IS tracked — needed for local recalibration
artifacts/models/*.pkl
artifacts/models/*.joblib

# Secrets
.env
.env.local
credentials.json
*.key
api_keys.yaml

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Pine local/debug builds — canonical deploy is pace_algo_v1.pine (tracked).
# Debug builds are local & regenerable, kept out of the deploy path.
*_debug.pine

# FX export smoke artifacts (regenerable via scripts/fx_primary_export_smoke.py)
artifacts/models/fx_primary_long_50t*
*.pine.txt

# Logs
*.log
logs/

# Keep directory structure but ignore content
!data_cache/raw/.gitkeep
!data_cache/processed/.gitkeep
!artifacts/models/.gitkeep
