f_pL(f_hour_cos, f_hour_sin, f_rvol_20, f_ema_20_dist_atr, f_atr_pct, f_htf_4h_rsi_14, f_is_fx_market_open, f_in_ny, f_htf_4h_atr_percentile_100) =>
    t_0 = (f_hour_sin <= -0.7147353589534758 ? (f_hour_cos <= 0.4904943853616715 ? -0.41637890861401483 : (f_hour_cos <= 0.6173424422740937 ? -0.4362273904224293 : -0.4571893043561349)) : (f_ema_20_dist_atr <= -0.24129600077867505 ? (f_rvol_20 <= 0.194383479654789 ? -0.379125978542432 : -0.4091586470285055) : (f_hour_sin <= -0.5280364453792571 ? -0.4263974760313123 : -0.4127353075668896)))
    t_1 = (f_hour_sin <= -0.7147353589534758 ? (f_hour_cos <= 0.5093866288661958 ? 0.018581482566841282 : (f_hour_cos <= 0.6343555450439454 ? -0.002200918331530632 : -0.02232903907478832)) : (f_ema_20_dist_atr <= -0.24129600077867505 ? (f_rvol_20 <= 0.194383479654789 ? 0.05363554584375078 : 0.02559123338609995) : (f_hour_sin <= -0.5280364453792571 ? 0.00934296490264464 : 0.022229565103100715)))
