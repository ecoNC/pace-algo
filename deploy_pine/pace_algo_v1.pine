    t_82 = (f_adx_14 <= 48.10339546203614 ? (f_bars_since_vol_spike <= 23.500000000000004 ? (f_hour_sin <= 0.9433113634586335 ? -0.0041757234407940975 : 0.02133614061952177) : (f_htf_4h_ema_alignment <= 1.0000000180025095e-35 ? -0.0013010622518142346 : 0.002999409611863475)) : (f_ema_20_dist_atr <= -1.1941837072372434 ? -0.013599869355159397 : (f_hour_cos <= -0.22706275433301923 ? 0.019525910319447774 : 0.0025759230932255427)))
    t_83 = (f_dist_to_sl_atr_conf <= 5.890921831130982 ? (f_adx_14 <= 47.272697448730476 ? (f_bars_since_vol_spike <= 23.500000000000004 ? -0.0034551260348374656 : 0.0007401777553684449) : (f_ema_50_dist_atr <= -4.071289300918578 ? -0.012819160102715221 : 0.015914792582656587)) : (f_bars_since_vol_spike <= 56.50000000000001 ? 0.0014765754636037363 : (f_fvg_bear_size_atr <= 0.21298677474260333 ? -0.028495428596324132 : -0.006255930141184038)))
    t_84 = (f_fvg_bull_size_atr <= 0.3754991292953492 ? (f_fvg_bear_size_atr <= 0.1543996632099152 ? (f_htf_1h_rsi_14 <= 46.62572288513184 ? -0.026885339577638175 : -0.005481303658671374) : (f_ema_50_dist_atr <= 0.5927239358425141 ? 0.000708953580530359 : -0.005500281673535073)) : (f_hour_cos <= 0.9568834006786348 ? 0.0002075570588162034 : (f_ema_200_dist_atr <= -5.985744237899779 ? -0.01519424157154156 : 0.01149355054779835)))
    t_85 = (f_momentum_composite <= 0.24295564740896228 ? (f_htf_1h_rsi_14 <= 40.75735473632813 ? 0.0038166734914621215 : (f_htf_1h_rsi_14 <= 41.118127822875984 ? -0.02753112671137925 : 0.000436389925334433)) : (f_rsi_14 <= 49.43612289428712 ? (f_hour_cos <= 0.6343555450439454 ? -0.01081661073521663 : -0.042252500648859805) : (f_macd_hist_atr <= 0.28910733759403234 ? -0.004841400318677707 : 0.004597192162408094)))
    t_86 = (f_htf_4h_atr_percentile_100 <= 0.975000023841858 ? (f_rvol_20 <= 2.3919361829757695 ? (f_vol_expansion_ratio <= 0.46880449354648596 ? 0.023822595076963042 : 0.0004217921178676367) : 0.011659686510207865) : (f_bars_since_vol_spike <= 97.50000000000001 ? (f_realized_vol_20 <= 0.002174496767111123 ? -0.019950161368110342 : -0.00020777380004416242) : (f_ema_200_dist_atr <= -9.063537597656248 ? 0.03323523585687421 : -0.0010425180736156545)))
    t_87 = (f_momentum_composite <= 0.24295564740896228 ? (f_htf_4h_ema_alignment <= -1.0000000180025095e-35 ? (f_vol_expansion_ratio <= 0.9627695381641389 ? -0.004653451631525281 : 0.0027194167196589007) : (f_is_fx_market_open <= 1.0000000180025095e-35 ? 0.021591075726273765 : 0.0018047155822731545)) : (f_momentum_composite <= 0.5407075881958009 ? (f_macd_hist_atr <= 0.47085402905941015 ? -0.0039706155569342915 : -0.028189154549535883) : 0.010328947192488279))
    t_88 = (f_htf_1h_rsi_14 <= 40.75735473632813 ? (f_atr_pct <= 0.00040293573692906653 ? (f_adx_14 <= 24.281064033508304 ? 0.013105316330274766 : 0.0015079508386632561) : (f_hour_sin <= 0.8713760673999787 ? -0.002173663633115161 : 0.01289758489453444)) : (f_htf_1h_rsi_14 <= 40.96445274353028 ? -0.03241695056994863 : (f_ema_200_dist_atr <= -4.309531927108764 ? -0.013045006668559754 : -1.3242726332294073e-05)))
    t_89 = (f_momentum_composite <= 0.24295564740896228 ? (f_hour_cos <= 0.6993099153041841 ? (f_hour_cos <= 0.6173424422740937 ? 0.0006671744729341724 : -0.010090634993768992) : 0.0032510601103297623) : (f_rsi_14 <= 49.43612289428712 ? (f_hour_cos <= 0.6343555450439454 ? -0.009928409134491842 : -0.03985191541227251) : (f_macd_hist_atr <= 0.28910733759403234 ? -0.004462348009618914 : 0.004357856868199815)))
    t_90 = (f_vol_expansion_ratio <= 0.46880449354648596 ? 0.022014727513894702 : (f_fvg_bull_size_atr <= 1.0968684554100039 ? (f_dist_to_swing_low_atr <= 1.08441436290741 ? 0.005505696361597468 : -0.0009742934562344592) : (f_bars_since_vol_spike <= 80.50000000000001 ? 0.008439151889610433 : -0.0018864872336489128)))
    t_91 = (f_vol_expansion_ratio <= 0.46880449354648596 ? 0.020939245707157723 : (f_htf_4h_atr_percentile_100 <= 0.634999990463257 ? (f_htf_4h_atr_percentile_100 <= 0.2950000017881394 ? -0.0014431476041295156 : 0.0038560044242375233) : (f_adx_14 <= 15.686963081359865 ? -0.009797406846924192 : -0.0005740431562458944)))
    t_92 = (f_fvg_bull_size_atr <= 0.7368348836898805 ? (f_htf_4h_rsi_14 <= 27.343670845031742 ? (f_vol_pct_diff_htf <= -0.3650000095367431 ? 0.023331686349449897 : 0.0012066790144038113) : (f_hour_cos <= -0.9108096361160277 ? -0.006106386914191834 : -0.0005416707676845345)) : (f_rsi_14 <= 37.726724624633796 ? -0.030418257866464626 : (f_htf_1h_ema_alignment <= 1.0000000180025095e-35 ? 0.00014672386563906715 : 0.006351849783922354)))
    t_93 = (f_vol_expansion_ratio <= 0.46880449354648596 ? 0.019880133747025446 : (f_htf_1h_rsi_14 <= 40.75735473632813 ? (f_hour_sin <= -0.8374305069446563 ? 0.008980505533525064 : 4.5059507499208134e-05) : (f_htf_1h_rsi_14 <= 40.96445274353028 ? -0.031731208699796364 : -0.0006511366324393524)))
    t_94 = (f_fvg_bull_size_atr <= 1.0968684554100039 ? (f_dist_to_swing_low_atr <= 1.08441436290741 ? 0.005668984848035817 : (f_htf_4h_atr_percentile_100 <= 0.09500000253319742 ? -0.004583036220018513 : -0.00020160039671501554)) : (f_bars_since_vol_spike <= 80.50000000000001 ? (f_hour_cos <= -0.2057649716734886 ? 0.01624806276530336 : 0.0013186691698219837) : (f_vol_expansion_ratio <= 0.7360213696956636 ? 0.012499302240098624 : -0.004814981799542348)))
    t_95 = (f_vol_expansion_ratio <= 2.1925189495086674 ? (f_dist_to_swing_low_atr <= 6.258985042572022 ? (f_hour_cos <= 0.9568834006786348 ? 0.0002472295871978619 : 0.005525339725120874) : (f_atr_percentile_100 <= 0.8750000000000001 ? -0.023636906204651427 : 0.01710306748391798)) : -0.02167161609366891)
    t_96 = (f_vol_expansion_ratio <= 2.027648210525513 ? (f_fvg_bear_size_atr <= 1.7375241518020632 ? (f_realized_vol_20 <= 0.005042017437517644 ? 0.0003903844504562552 : -0.018139294505816663) : (f_htf_4h_atr_percentile_100 <= 0.3949999958276749 ? -0.0026740827983824204 : 0.01333434015540256)) : (f_htf_1h_ema_alignment <= 1.0000000180025095e-35 ? -0.02746370958869473 : -0.0013321074989840623))
    t_97 = (f_hour_cos <= -0.9108096361160277 ? (f_vol_pct_diff_htf <= -0.524999976158142 ? (f_vol_contracting <= 1.0000000180025095e-35 ? -0.008167581106445656 : -0.04177077959050379) : (f_dist_to_bear_fvg_atr <= -0.19185777753591535 ? -0.00010365347480972075 : -0.013622334462303523)) : (f_dist_to_sh_atr_conf <= 3.104215502738953 ? (f_ema_200_dist_atr <= -13.241097450256346 ? 0.026129364606999706 : 0.0015937818068433836) : -0.0012270362313435556))
    t_98 = (f_vol_pct_diff_htf <= -0.8749999999999999 ? (f_volume_z_score <= -1.0418691635131834 ? -0.030403416601093265 : (f_htf_4h_rsi_14 <= 63.92534828186036 ? -0.007708466905710899 : 0.015465035997594651)) : (f_htf_1h_rsi_14 <= 83.18564987182619 ? (f_htf_1h_rsi_14 <= 52.945161819458015 ? 0.0017330326070244132 : -0.0011323435268211417) : 0.021779189607674332))
    t_99 = (f_vol_expansion_ratio <= 2.1925189495086674 ? (f_dist_to_swing_low_atr <= 6.258985042572022 ? (f_hour_cos <= 0.9568834006786348 ? 0.0001792451566319746 : 0.005126278783748928) : (f_atr_percentile_100 <= 0.8750000000000001 ? -0.022460387638601254 : 0.0164193597408228)) : -0.019956396001635096)
    raw = t_0 + t_1 + t_2 + t_3 + t_4 + t_5 + t_6 + t_7 + t_8 + t_9 + t_10 + t_11 + t_12 + t_13 + t_14 + t_15 + t_16 + t_17 + t_18 + t_19 + t_20 + t_21 + t_22 + t_23 + t_24 + t_25 + t_26 + t_27 + t_28 + t_29 + t_30 + t_31 + t_32 + t_33 + t_34 + t_35 + t_36 + t_37 + t_38 + t_39 + t_40 + t_41 + t_42 + t_43 + t_44 + t_45 + t_46 + t_47 + t_48 + t_49 + t_50 + t_51 + t_52 + t_53 + t_54 + t_55 + t_56 + t_57 + t_58 + t_59 + t_60 + t_61 + t_62 + t_63 + t_64 + t_65 + t_66 + t_67 + t_68 + t_69 + t_70 + t_71 + t_72 + t_73 + t_74 + t_75 + t_76 + t_77 + t_78 + t_79 + t_80 + t_81 + t_82 + t_83 + t_84 + t_85 + t_86 + t_87 + t_88 + t_89 + t_90 + t_91 + t_92 + t_93 + t_94 + t_95 + t_96 + t_97 + t_98 + t_99
    1.0 / (1.0 + math.exp(-raw))

probability = f_pace_algo_v1_probability(f_ema_20_dist_atr, f_ema_50_dist_atr, f_ema_200_dist_atr, f_ema_20_slope_atr, f_ema_alignment, f_adx_14, f_adx_slope, f_rsi_14, f_stoch_rsi_k, f_roc_10, f_macd_hist_atr, f_momentum_composite, f_atr_pct, f_atr_percentile_100, f_bb_width_pct, f_vol_compression, f_realized_vol_20, f_dist_to_swing_high_atr, f_dist_to_swing_low_atr, f_rvol_20, f_volume_z_score, f_hour_sin, f_hour_cos, f_htf_1h_ema_alignment, f_htf_1h_rsi_14, f_htf_1h_atr_percentile_100, f_htf_4h_ema_alignment, f_htf_4h_rsi_14, f_htf_4h_atr_percentile_100, f_eqhigh_present, f_dist_to_sh_atr_conf, f_dist_to_sl_atr_conf, f_dist_to_bull_fvg_atr, f_dist_to_bear_fvg_atr, f_fvg_bull_size_atr, f_fvg_bear_size_atr, f_in_asia, f_in_ny, f_is_fx_market_open, f_vol_expansion_ratio, f_vol_contracting, f_bars_since_vol_spike, f_htf_ltf_agree_bull, f_htf_ltf_alignment_score, f_ltf_rsi_minus_htf_rsi, f_vol_pct_diff_htf, f_both_high_vol, f_both_low_vol, f_pullback_in_bull)

// Tier-Cutoffs.
// V1-FINAL: aus NB16 v1b (LightGBM 100 trees, seed=42):
//           q90=0.531 / q97=0.548 / q99=0.565 — werden via pine_codegen eingesetzt.
// SKELETON-TEST: RSI-basierter Placeholder → proba = rsi/100.
//                Cutoffs entsprechen RSI 55/60/65 (typische Overbought-Schwellen).
//                Wird in Build 2 ersetzt.
var float CUTOFF_STANDARD = 0.5353   // Aggressive trigger (skeleton-test, RSI>55)
var float CUTOFF_HIGH     = 0.5539   // Balanced           (skeleton-test, RSI>60)
var float CUTOFF_PREMIUM  = 0.5772   // Conservative       (skeleton-test, RSI>65)

tier = probability >= CUTOFF_PREMIUM ? "Premium" : probability >= CUTOFF_HIGH ? "High" : probability >= CUTOFF_STANDARD ? "Standard" : "None"

// Profile mapping (ANN-012 + ANN-018)
profile_cutoff = profile == "Aggressive" ? CUTOFF_STANDARD : profile == "Balanced" ? CUTOFF_HIGH : CUTOFF_PREMIUM

signal_raw = probability >= profile_cutoff

// Optional Session-Filter (User-Choice, NICHT Curve-Fit)
hour_utc = hour(time, "UTC")
in_ny_session = hour_utc >= 13 and hour_utc < 22
in_asia_session = hour_utc >= 23 or hour_utc < 8
session_allowed = switch i_session_filter
    "NY only"      => in_ny_session
    "Exclude Asia" => not in_asia_session
    => true

signal_active = signal_raw and session_allowed


// =============================================================================
// LAYER 2 — MULTI-TF DASHBOARD (5m / 15m / 1h / 4h)
// =============================================================================
// Pro TF: Trend (EMA20 vs EMA50) / Strength (ADX14) / Range (Bollinger-Width
//         relativ zu eigenem 50-Bar-Average).
// Aggregat: TF-gewichtet (4h=4× / 1h=2× / 15m=1× / 5m=0.5×) → Score in [-1, +1].
// =============================================================================

// --- Per-TF Berechnungs-Funktionen (Lookahead-Off zwingend) ---

f_trend_score(tf_str) =>
    e20 = request.security(syminfo.tickerid, tf_str, ta.ema(close, 20), barmerge.gaps_off, barmerge.lookahead_off)
    e50 = request.security(syminfo.tickerid, tf_str, ta.ema(close, 50), barmerge.gaps_off, barmerge.lookahead_off)
    e20 > e50 ? 1 : e20 < e50 ? -1 : 0

// ta.adx() reported "Could not find function" in some Pine v6 environments —
// use ta.dmi() which returns [+DI, -DI, ADX] and pick the third value.
f_adx_helper() =>
    [_diPlus, _diMinus, _adx_val] = ta.dmi(14, 14)
    _adx_val

f_adx_value(tf_str) =>
    request.security(syminfo.tickerid, tf_str, f_adx_helper(), barmerge.gaps_off, barmerge.lookahead_off)

// Bollinger-Width-Ratio: aktueller Width / SMA(Width, 50)
// Self-contained Helper damit es in request.security passt.
f_bb_width_ratio() =>
    basis = ta.sma(close, 20)
    dev = 2.0 * ta.stdev(close, 20)
    width = basis > 0 ? (2 * dev) / basis : 0.0
    width_avg = ta.sma(width, 50)
    width_avg > 0 ? width / width_avg : 1.0

f_range_ratio(tf_str) =>
    request.security(syminfo.tickerid, tf_str, f_bb_width_ratio(), barmerge.gaps_off, barmerge.lookahead_off)

// --- Per-TF Werte holen ---

trend_5m  = f_trend_score("5")
trend_15m = f_trend_score("15")
trend_1h  = f_trend_score("60")
trend_4h  = f_trend_score("240")

adx_5m   = f_adx_value("5")
adx_15m  = f_adx_value("15")
adx_1h   = f_adx_value("60")
adx_4h   = f_adx_value("240")

range_5m  = f_range_ratio("5")
range_15m = f_range_ratio("15")
range_1h  = f_range_ratio("60")
range_4h  = f_range_ratio("240")

// --- Label-Konversion ---

f_strength_label(adx_val) =>
    adx_val > 25 ? "High" : adx_val > 15 ? "Med" : "Lo"

f_range_label(ratio) =>
    ratio < 0.5 ? "Strong" : ratio < 0.8 ? "Yes" : "No"

f_trend_label(score) =>
    score == 1 ? "▲ Up" : score == -1 ? "▼ Down" : "─ Neutral"

f_trend_color(score) =>
    score == 1 ? color.new(color.green, 70) : score == -1 ? color.new(color.red, 70) : color.new(color.gray, 80)

// --- Overall Market State (TF-gewichtet) ---
// 4h = 4× / 1h = 2× / 15m = 1× / 5m = 0.5×  → Summe Gewichte = 7.5

weighted_sum = 4.0 * trend_4h + 2.0 * trend_1h + 1.0 * trend_15m + 0.5 * trend_5m
weight_total = 7.5
market_state_score = weighted_sum / weight_total   // [-1, +1]

market_state_label = market_state_score > 0.50 ? "Strong Bullish" : market_state_score > 0.20 ? "Bullish" : market_state_score > -0.20 ? "Neutral" : market_state_score > -0.50 ? "Bearish" : "Strong Bearish"

market_state_color = market_state_score > 0.20 ? color.new(color.green, 60) : market_state_score < -0.20 ? color.new(color.red, 60) : color.new(color.gray, 70)


// =============================================================================
// LAYER 3 — BACKTEST / SETTINGS TRANSPARENCY
// =============================================================================
// Live PF/WR/MDD-Tracking auf den sichtbaren Bars (current chart period).
// Trade-Simulation: TP = 1.5 × ATR / SL = 1.0 × ATR  (Triple-Barrier-Equivalent).
// =============================================================================

var int   bt_wins    = 0
var int   bt_losses  = 0
var float bt_equity  = 0.0
var float bt_peak    = 0.0
var float bt_max_dd  = 0.0

var bool  in_trade   = false
var float entry_px   = na
var float tp_px      = na
var float sl_px      = na

// Reset bei Profile-Wechsel oder neuer Symbol-Session — nicht nötig hier weil
// `var` über bars persistiert, Reset erfolgt nur bei Indicator-Re-Add.

// Trade-Logic (simplified — keine Pyramiding, immer eine offene Position)
if signal_active and not in_trade
    entry_px := close
    atr_now = ta.atr(14)
    tp_px   := entry_px + 1.5 * atr_now
    sl_px   := entry_px - 1.0 * atr_now
    in_trade := true

if in_trade
    // TP zuerst checken bei beidem-touched-Bar = konservative Annahme SL first
    if low <= sl_px
        bt_losses += 1
        bt_equity -= 1.0
        in_trade  := false
    else if high >= tp_px
        bt_wins   += 1
        bt_equity += 1.5
        in_trade  := false

// Drawdown-Tracking
if bt_equity > bt_peak
    bt_peak := bt_equity

bt_dd_abs = bt_peak - bt_equity
bt_dd_pct = bt_peak > 0 ? bt_dd_abs / bt_peak : 0.0
if bt_dd_pct > bt_max_dd
    bt_max_dd := bt_dd_pct

bt_total_trades = bt_wins + bt_losses
bt_wr  = bt_total_trades > 0 ? bt_wins / bt_total_trades : 0.0
bt_gross_win  = bt_wins * 1.5
bt_gross_loss = bt_losses * 1.0
bt_pf = bt_gross_loss > 0 ? bt_gross_win / bt_gross_loss : (bt_gross_win > 0 ? 999.0 : 0.0)


// =============================================================================
// UI — DASHBOARD-TABELLE
// =============================================================================

if show_dashboard and barstate.islast
    var table dash = table.new(position.top_right, 5, 6, border_width=1, border_color=color.new(color.gray, 60))
    bg_header = color.new(color.black, 50)
    txt_header = color.white

    table.cell(dash, 0, 0, "TF",       bgcolor=bg_header, text_color=txt_header, text_size=size.small)
    table.cell(dash, 1, 0, "Trend",    bgcolor=bg_header, text_color=txt_header, text_size=size.small)
    table.cell(dash, 2, 0, "Strength", bgcolor=bg_header, text_color=txt_header, text_size=size.small)
    table.cell(dash, 3, 0, "Range",    bgcolor=bg_header, text_color=txt_header, text_size=size.small)
    table.cell(dash, 4, 0, "ADX",      bgcolor=bg_header, text_color=txt_header, text_size=size.small)

    // Row: 5m
    table.cell(dash, 0, 1, "5m",                                                                text_size=size.small)
    table.cell(dash, 1, 1, f_trend_label(trend_5m), bgcolor=f_trend_color(trend_5m),            text_size=size.small)
    table.cell(dash, 2, 1, f_strength_label(adx_5m),                                            text_size=size.small)
    table.cell(dash, 3, 1, f_range_label(range_5m),                                             text_size=size.small)
    table.cell(dash, 4, 1, str.tostring(adx_5m, "#.#"),                                         text_size=size.small)

    // Row: 15m
    table.cell(dash, 0, 2, "15m",                                                               text_size=size.small)
    table.cell(dash, 1, 2, f_trend_label(trend_15m), bgcolor=f_trend_color(trend_15m),          text_size=size.small)
    table.cell(dash, 2, 2, f_strength_label(adx_15m),                                           text_size=size.small)
    table.cell(dash, 3, 2, f_range_label(range_15m),                                            text_size=size.small)
    table.cell(dash, 4, 2, str.tostring(adx_15m, "#.#"),                                        text_size=size.small)

    // Row: 1h
    table.cell(dash, 0, 3, "1h",                                                                text_size=size.small)
    table.cell(dash, 1, 3, f_trend_label(trend_1h), bgcolor=f_trend_color(trend_1h),            text_size=size.small)
    table.cell(dash, 2, 3, f_strength_label(adx_1h),                                            text_size=size.small)
    table.cell(dash, 3, 3, f_range_label(range_1h),                                             text_size=size.small)
    table.cell(dash, 4, 3, str.tostring(adx_1h, "#.#"),                                         text_size=size.small)

    // Row: 4h
    table.cell(dash, 0, 4, "4h",                                                                text_size=size.small)
    table.cell(dash, 1, 4, f_trend_label(trend_4h), bgcolor=f_trend_color(trend_4h),            text_size=size.small)
    table.cell(dash, 2, 4, f_strength_label(adx_4h),                                            text_size=size.small)
    table.cell(dash, 3, 4, f_range_label(range_4h),                                             text_size=size.small)
    table.cell(dash, 4, 4, str.tostring(adx_4h, "#.#"),                                         text_size=size.small)

    // Row: Overall State
    table.cell(dash, 0, 5, "Overall",      bgcolor=bg_header,         text_color=txt_header,  text_size=size.small)
    table.cell(dash, 1, 5, market_state_label, bgcolor=market_state_color, text_color=color.white, text_size=size.small)
    table.cell(dash, 2, 5, str.tostring(market_state_score, "#.##"), bgcolor=market_state_color, text_color=color.white, text_size=size.small)
    table.cell(dash, 3, 5, "")
    table.cell(dash, 4, 5, "")


// =============================================================================
// UI — BACKTEST-STATS-TABELLE
// =============================================================================

if show_backtest and barstate.islast
    var table stats = table.new(position.bottom_right, 2, 11, border_width=1, border_color=color.new(color.gray, 60))
    bg_h = color.new(color.black, 50)
    txt_h = color.white

    table.cell(stats, 0, 0, "Backtest (visible bars)", bgcolor=bg_h, text_color=txt_h, text_size=size.small)
    table.cell(stats, 1, 0, "Value",                    bgcolor=bg_h, text_color=txt_h, text_size=size.small)

    table.cell(stats, 0, 1, "Profile",                                       text_size=size.small)
    table.cell(stats, 1, 1, profile,                                          text_size=size.small)

    table.cell(stats, 0, 2, "Session Filter",                                 text_size=size.small)
    table.cell(stats, 1, 2, i_session_filter,                                 text_size=size.small)

    // === Diagnose: aktuelle Probability + Active Cutoff (Transparenz) ===
    table.cell(stats, 0, 3, "Current Proba", bgcolor=color.new(color.navy, 80), text_size=size.small)
    proba_color = probability >= profile_cutoff ? color.new(color.green, 70) : color.new(color.gray, 80)
    table.cell(stats, 1, 3, str.tostring(probability, "#.###"), bgcolor=proba_color, text_size=size.small)

    table.cell(stats, 0, 4, "Active Cutoff", bgcolor=color.new(color.navy, 80), text_size=size.small)
    table.cell(stats, 1, 4, str.tostring(profile_cutoff, "#.###"), text_size=size.small)

    table.cell(stats, 0, 5, "Current Tier", bgcolor=color.new(color.navy, 80), text_size=size.small)
    tier_color = tier == "Premium" ? color.new(color.yellow, 60) : tier == "High" ? color.new(color.lime, 70) : tier == "Standard" ? color.new(color.aqua, 70) : color.new(color.gray, 80)
    table.cell(stats, 1, 5, tier, bgcolor=tier_color, text_size=size.small)

    // === Stats ===
    table.cell(stats, 0, 6, "Trades",                                         text_size=size.small)
    table.cell(stats, 1, 6, str.tostring(bt_total_trades),                    text_size=size.small)

    table.cell(stats, 0, 7, "Win Rate", text_size=size.small)
    wr_color = bt_wr >= 0.55 ? color.new(color.green, 70) : bt_wr >= 0.45 ? color.new(color.gray, 80) : color.new(color.red, 70)
    table.cell(stats, 1, 7, str.tostring(bt_wr * 100, "#.#") + "%", bgcolor=wr_color, text_size=size.small)

    table.cell(stats, 0, 8, "Profit Factor", text_size=size.small)
    pf_color = bt_pf >= 1.5 ? color.new(color.green, 70) : bt_pf >= 1.0 ? color.new(color.gray, 80) : color.new(color.red, 70)
    table.cell(stats, 1, 8, str.tostring(bt_pf, "#.##"), bgcolor=pf_color, text_size=size.small)

    table.cell(stats, 0, 9, "Max Drawdown", text_size=size.small)
    dd_color = bt_max_dd <= 0.10 ? color.new(color.green, 70) : bt_max_dd <= 0.20 ? color.new(color.gray, 80) : color.new(color.red, 70)
    table.cell(stats, 1, 9, str.tostring(bt_max_dd * 100, "#.#") + "%", bgcolor=dd_color, text_size=size.small)

    table.cell(stats, 0, 10, "Current Equity",                                text_size=size.small)
    table.cell(stats, 1, 10, str.tostring(bt_equity, "#.##") + " R",          text_size=size.small)


// =============================================================================
// UI — SIGNAL-VISUALISIERUNG
// =============================================================================

if show_signals and signal_active and not in_trade[1]
    label_color = tier == "Premium" ? color.yellow : tier == "High" ? color.lime : color.aqua
    label.new(bar_index, low, "▲ " + tier, style=label.style_label_up, color=label_color, textcolor=color.black, size=size.small)

// TP/SL Boxen für aktuell offenen Trade
var box current_trade_box = na
if in_trade and not in_trade[1]
    current_trade_box := box.new(bar_index, tp_px, bar_index, sl_px, border_color=color.new(color.blue, 50), bgcolor=color.new(color.blue, 90))

if not in_trade and not na(current_trade_box)
    box.set_right(current_trade_box, bar_index)
    current_trade_box := na
